{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|apple-touch-icon|png|otf|ttf|woff|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "supabase-api",
      "urls": [
        "https://*.supabase.co/**"
      ],
      "cacheConfig": {
        "maxSize": 0,
        "maxAge": "0s",
        "strategy": "freshness"
      }
    },
    {
      "name": "internal-api",
      "urls": [
        "/api/**"
      ],
      "cacheConfig": {
        "maxSize": 0,
        "maxAge": "0s",
        "strategy": "freshness"
      }
    }
  ]
}
